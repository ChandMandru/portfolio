# Anthropic API key for Claude chatbot
# Get yours at: https://console.anthropic.com -> API Keys -> Create Key
# IMPORTANT: Set a hard monthly spend cap (~5 EUR / ~5.50 USD) at
#   https://console.anthropic.com/settings/billing
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Upstash Redis for rate limiting (optional in development)
# Create a free database at: https://console.upstash.com
# Then copy REST API credentials from the database dashboard
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
